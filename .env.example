# Copy this file to .env and fill in your API keys.
# Never commit .env to version control.

# Required for LLM summarisation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — raises CORE rate limit. Free key at https://core.ac.uk/services/api
CORE_API_KEY=

# Optional — used for Landmark Papers resolution. Without it, Semantic Scholar
# is rate-limited and the pipeline falls back to OpenAlex (which undercounts
# citations and misses some preprints like Self-RAG/ReAct). A free key gives
# accurate citation counts and reliable resolution.
# Get one at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
